          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "categorias"
          ]
        },
        "description": "Demuestra CRUD exitoso en ms-productos y genera categoriaId.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Booster Boxes\",\n  \"descripcion\": \"Cajas de sobres selladas de Pokémon TCG\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status esperado: 201', function () {",
              "    pm.expect([201]).to.include(pm.response.code);",
              "});",
              "let data = {};",
              "try { data = pm.response.json(); } catch (e) {}",
              "if (data.id) pm.collectionVariables.set('categoriaId', data.id);",
              "if (data.id) console.log('Variable guardada: categoriaId = ' + data.id);"
            ]
